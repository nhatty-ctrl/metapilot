# Gemini API Configuration - Required
# Get your API key from: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Database Configuration
# For local PostgreSQL development:
# DATABASE_URL=postgresql://username:password@localhost:5432/yield_autopilot
# 
# For Supabase (recommended for production):
# DATABASE_URL=postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/yield_autopilot

# Environment
NODE_ENV=development
PORT=3000

# CORS - Update FRONTEND_URL if frontend is on a different origin
FRONTEND_URL=http://localhost:5173

# App URL (for deployment)
APP_URL=http://localhost:3000
